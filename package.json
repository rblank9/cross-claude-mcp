{
  "name": "cross-claude-mcp",
  "version": "2.0.0",
  "description": "MCP server enabling multiple Claude instances to communicate and collaborate across Claude Code, Claude.ai, and Claude Desktop",
  "type": "module",
  "main": "server.mjs",
  "bin": {
    "cross-claude-mcp": "./server.mjs"
  },
  "scripts": {
    "start": "node server.mjs",
    "start:saas": "node saas/server-saas.mjs",
    "test": "node test.mjs"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "multi-agent",
    "collaboration",
    "message-bus",
    "model-context-protocol"
  ],
  "author": "Shield Your Body LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/rblank9/cross-claude-mcp.git"
  },
  "homepage": "https://github.com/rblank9/cross-claude-mcp",
  "bugs": {
    "url": "https://github.com/rblank9/cross-claude-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "connect-pg-simple": "^10.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "pg": "^8.13.0",
    "stripe": "^17.5.0"
  },
  "license": "MIT"
